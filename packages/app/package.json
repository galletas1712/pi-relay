{
	"name": "@pi-relay/app",
	"version": "0.1.0",
	"description": "Entry point: wires agent-core + orchestrator + coding-agent SDK into TUI or RPC",
	"type": "module",
	"main": "./dist/index.js",
	"bin": {
		"pi-relay": "./dist/index.js"
	},
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x dist/index.js",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"start": "node dist/index.js",
		"test": "vitest --run"
	},
	"dependencies": {
		"@mariozechner/pi-agent-core": "^0.66.1",
		"@mariozechner/pi-ai": "^0.67.3",
		"@mariozechner/pi-coding-agent": "^0.67.3",
		"@pi-relay/orchestrator": "^0.1.0",
		"@sinclair/typebox": "^0.34.41",
		"diff": "^8.0.2",
		"file-type": "^21.1.1"
	},
	"devDependencies": {
		"@types/node": "^22.10.5",
		"typescript": "^5.9.2"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
