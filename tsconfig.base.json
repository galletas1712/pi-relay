{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"inlineSources": true,
		"inlineSourceMap": false,
		"moduleResolution": "Node16",
		"resolveJsonModule": true,
		"paths": {
			"@pi-relay/agent-core": ["./packages/agent-core/dist/index.d.ts"],
			"@pi-relay/agent-core/*": ["./packages/agent-core/dist/*"],
			"@pi-relay/agent-protocol": ["./packages/agent-protocol/dist/index.d.ts"],
			"@pi-relay/agent-protocol/*": ["./packages/agent-protocol/dist/*"],
			"@pi-relay/orchestrator-core": ["./packages/orchestrator-core/dist/index.d.ts"],
			"@pi-relay/orchestrator-core/*": ["./packages/orchestrator-core/dist/*"]
		},
		"allowImportingTsExtensions": false,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"useDefineForClassFields": false,
		"types": ["node"]
	}
}
